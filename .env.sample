# ============================================
# MIAUZAP CONFIGURATION FILE
# ============================================
# This is a sample environment configuration file for Miauzap.
# Copy this file to .env and configure according to your needs.
# Lines starting with # are comments and optional configurations.

# ============================================
# SERVER CONFIGURATION (Required)
# ============================================

# Server URL - IMPORTANT: Set this to your domain in production
# This is used for generating webhook URLs for Chatwoot integration
# Examples:
#   Production: https://miauzap.yourdomain.com
#   Development: http://localhost:8080
SERVER_URL=http://localhost:8080

# Server bind address (0.0.0.0 allows external connections)
MIAUZAP_ADDRESS=0.0.0.0

# Server port (change if using Traefik or reverse proxy)
MIAUZAP_PORT=8080

# ============================================
# SECURITY CONFIGURATION (Required)
# ============================================

# Admin token for administrative operations
# Generate a strong random token for production
MIAUZAP_ADMIN_TOKEN=your_secure_admin_token_here

# Global encryption key for sensitive data (MUST be exactly 32 bytes for AES-256)
# CRITICAL: Save this key securely! If lost, encrypted data cannot be recovered
# Generate with: openssl rand -base64 32
MIAUZAP_GLOBAL_ENCRYPTION_KEY=your_32_byte_encryption_key_here_12

# Global HMAC key for webhook signing (minimum 32 characters)
# Used to sign webhook payloads for verification
# Generate with: openssl rand -base64 32
MIAUZAP_GLOBAL_HMAC_KEY=your_global_hmac_key_minimum_32_chars

# ============================================
# WEBHOOK CONFIGURATION (Optional)
# ============================================

# Global webhook URL to receive all events from all instances
# Leave empty if not using global webhooks
#MIAUZAP_GLOBAL_WEBHOOK=https://your-webhook-endpoint.com/webhook

# Webhook payload format: "json" or "form"
WEBHOOK_FORMAT=json

# Webhook retry configuration
#WEBHOOK_RETRY_ENABLED=true
#WEBHOOK_RETRY_COUNT=5
#WEBHOOK_RETRY_DELAY_SECONDS=30
#WEBHOOK_ERROR_QUEUE_NAME=webhook_errors

# ============================================
# SESSION CONFIGURATION (Optional)
# ============================================

# Device name shown in WhatsApp linked devices
SESSION_DEVICE_NAME=Miauzap

# ============================================
# DATABASE CONFIGURATION (Required)
# ============================================

# PostgreSQL database credentials
DB_USER=miauzap
DB_PASSWORD=miauzap_secure_password
DB_NAME=miauzap

# Database host (use 'db' for Docker Compose, 'localhost' for native)
DB_HOST=db

# Database port
DB_PORT=5432

# SSL mode for PostgreSQL connection
# Options: disable, require, verify-ca, verify-full
DB_SSLMODE=disable

# Timezone configuration
TZ=America/Sao_Paulo

# ============================================
# RABBITMQ CONFIGURATION (Optional)
# ============================================

# RabbitMQ credentials (used by docker-compose.yml)
RABBITMQ_USER=miauzap
RABBITMQ_PASSWORD=miauzap_secure_password

# RabbitMQ connection URL
# Use 'rabbitmq' when running with Docker Compose
# Use 'localhost' for native execution
RABBITMQ_URL=amqp://miauzap:miauzap@rabbitmq:5672/

# RabbitMQ queue name for WhatsApp events
RABBITMQ_QUEUE=whatsapp_events

# ============================================
# TRAEFIK CONFIGURATION (Required for Production/Portainer)
# ============================================
# Only required if you are deploying via Portainer with Traefik enabled.
# Ensure `docker-compose.yml` has the Traefik labels uncommented.

# Your domain name (must point to your VPS IP via DNS)
# Example: miauzap.yourdomain.com
TRAEFIK_DOMAIN=miauzap.yourdomain.com

# Traefik network name (Must match your existing Traefik network)
# Common names: traefik-public, traefik_network, proxy
# This network must already exist in Portainer/Docker
TRAEFIK_NETWORK=traefik-public

# Let's Encrypt email for SSL certificate notifications
TRAEFIK_ACME_EMAIL=admin@yourdomain.com

# Traefik entrypoint for HTTPS traffic
# Default is 'websecure' (port 443)
TRAEFIK_ENTRYPOINT=websecure

# ============================================
# PORTAINER STACK & NETWORKS
# ============================================

# Stack/Project Name
# Used to prefix volumes and internal networks
# In Portainer, this is usually strictly controlled by the stack name,
# but setting it here ensures consistency.
COMPOSE_PROJECT_NAME=miauzap

# ============================================
# DOCKER VOLUMES & NETWORK CONFIGURATION
# ============================================

# Docker Compose project name
# This prefixes all container, network, and volume names
# Example: miauzap_db_data, miauzap_network
# COMPOSE_PROJECT_NAME=miauzap (Defined in Portainer Stack section above)

# Volume names (automatically prefixed with COMPOSE_PROJECT_NAME)
# These store persistent data for database and RabbitMQ
# Default names:
#   - miauzap_db_data (PostgreSQL data)
#   - miauzap_rabbitmq_data (RabbitMQ data)
# You can customize by setting these variables:
#DB_VOLUME_NAME=${COMPOSE_PROJECT_NAME}_db_data
#RABBITMQ_VOLUME_NAME=${COMPOSE_PROJECT_NAME}_rabbitmq_data

# Network configuration
# Internal network name for service-to-service communication
# Default: miauzap_network (automatically created)
#INTERNAL_NETWORK_NAME=${COMPOSE_PROJECT_NAME}_network

# ============================================
# DEPLOYMENT EXAMPLES
# ============================================

# EXAMPLE 1: Local Development (Default)
# - Uses port mapping (8080:8080)
# - No Traefik needed
# - Access via: http://localhost:8080
# Required variables:
#   SERVER_URL=http://localhost:8080
#   MIAUZAP_PORT=8080

# EXAMPLE 2: Production with Traefik
# - Uncomment Traefik labels in docker-compose.yml
# - Uncomment traefik-public network
# - Comment out port mapping
# Required variables:
#   SERVER_URL=https://miauzap.yourdomain.com
#   TRAEFIK_DOMAIN=miauzap.yourdomain.com
#   TRAEFIK_NETWORK=traefik-public
#   TRAEFIK_ACME_EMAIL=admin@yourdomain.com
#   TRAEFIK_ENTRYPOINT=websecure

# EXAMPLE 3: Portainer Deployment
# - Upload docker-compose.yml to Portainer
# - Set environment variables in Portainer UI
# - Deploy as a stack
# - Portainer will manage the containers

# ============================================
# NOTES
# ============================================
# 1. Always use strong, randomly generated passwords in production
# 2. Keep your .env file secure and never commit it to version control
# 3. Backup your MIAUZAP_GLOBAL_ENCRYPTION_KEY - data cannot be recovered without it
# 4. Set SERVER_URL to your actual domain when deploying to production
# 5. For Traefik setup, ensure your domain DNS points to your VPS IP
# 6. Volumes persist data even when containers are removed
# 7. Use 'docker volume ls' to list all volumes
# 8. Use 'docker network ls' to list all networks
